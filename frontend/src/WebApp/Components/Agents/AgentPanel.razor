<article class="@PanelCssClass" id="@PanelId">
    <header class="agent-panel-header">
        @if (IsCollapsible)
        {
            <button type="button"
                    class="agent-panel-toggle"
                    aria-expanded="@IsExpanded"
                    aria-controls="@BodyId"
                    @onclick="Toggle">
                <span class="agent-panel-heading">
                    <span class="agent-role">@Role</span>
                    <span class="agent-name">@AgentName</span>
                </span>
                @if (!string.IsNullOrWhiteSpace(StatusLabel))
                {
                    <span class="agent-status @StatusCssClass">@StatusLabel</span>
                }
            </button>
        }
        else
        {
            <div>
                <p class="agent-role">@Role</p>
                <h3 class="agent-name">@AgentName</h3>
            </div>
            @if (!string.IsNullOrWhiteSpace(StatusLabel))
            {
                <span class="agent-status @StatusCssClass">@StatusLabel</span>
            }
        }
    </header>
    @if (IsExpanded)
    {
        @if (!string.IsNullOrWhiteSpace(Purpose))
        {
            <p class="agent-purpose">@Purpose</p>
        }
        <div class="agent-panel-body" id="@BodyId">
            @ChildContent
        </div>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public string AgentName { get; set; } = string.Empty;

    [Parameter]
    public string Role { get; set; } = "Agent";

    [Parameter]
    public string? Purpose { get; set; }

    [Parameter]
    public string? StatusLabel { get; set; }

    [Parameter]
    public string StatusCssClass { get; set; } = "agent-status-neutral";

    [Parameter]
    public string CssClass { get; set; } = string.Empty;

    [Parameter]
    public string? PanelId { get; set; }

    [Parameter]
    public bool IsCollapsible { get; set; }

    [Parameter]
    public bool CollapsedByDefault { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private readonly string _bodyIdSuffix = Guid.NewGuid().ToString("N");
    private bool _isExpanded = true;

    private string BodyId => !string.IsNullOrWhiteSpace(PanelId)
        ? $"{PanelId}-agent-body"
        : $"agent-panel-{_bodyIdSuffix}-body";

    private string PanelCssClass =>
        $"agent-panel {CssClass} {(IsCollapsible ? "agent-panel-collapsible" : null)} {(IsExpanded ? "is-expanded" : "is-collapsed")}";

    private bool IsExpanded => !IsCollapsible || _isExpanded;

    protected override void OnInitialized()
    {
        _isExpanded = !CollapsedByDefault;
    }

    private void Toggle()
    {
        if (IsCollapsible)
        {
            _isExpanded = !_isExpanded;
        }
    }
}
