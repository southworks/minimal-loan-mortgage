@using Cohere.LoanProcessing.Shared.Contracts.Api.Cases
@using Cohere.LoanProcessing.WebApp.Models

<article class="agent-panel agent-placeholder @WorkflowStageUi.ToCssClass(ExecutionStatus)" id="@PanelId">
    <header class="agent-panel-header">
        <div>
            <p class="agent-role">@Role</p>
            <h3 class="agent-name">@AgentName</h3>
        </div>
        <span class="agent-status agent-status-neutral">@WorkflowStageUi.ToLabel(ExecutionStatus)</span>
    </header>
    <p class="agent-purpose">@Purpose</p>
    <p class="agent-placeholder-message">@GetMessage(ExecutionStatus)</p>
</article>

@code {
    [Parameter, EditorRequired]
    public string AgentName { get; set; } = string.Empty;

    [Parameter]
    public string Role { get; set; } = "Agent";

    [Parameter]
    public string Purpose { get; set; } = string.Empty;

    [Parameter]
    public string ExecutionStatus { get; set; } = "NotStarted";

    [Parameter]
    public string? PanelId { get; set; }

    private static string GetMessage(string executionStatus) => executionStatus switch
    {
        "InProgress" => "This agent is currently processing the case.",
        "Succeeded" => "Stage completed. Detailed output is available below.",
        "Failed" => "This stage failed. Check status notes and execution trace for details.",
        "Blocked" => "This stage is blocked pending review or remediation.",
        "Skipped" => "This stage was skipped because underwriting required human review first.",
        _ => "This stage has not started yet. Start the workflow to run the agent pipeline."
    };
}
