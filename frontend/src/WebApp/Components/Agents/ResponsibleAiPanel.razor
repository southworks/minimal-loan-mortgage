@using Cohere.LoanProcessing.Shared.Contracts.Api.Cases
@using Cohere.LoanProcessing.WebApp.Components.Common
@using Cohere.LoanProcessing.WebApp.Models

@if (Result is not null)
{
    var statusLabel = WorkflowStageUi.ResponsibleAiStatusLabel(Result);

    <AgentPanel AgentName="Fairness Review"
                Role="Stage 4"
                Purpose="Review governance signals, fairness concerns, and decision consistency before account setup."
                StatusLabel="@statusLabel"
                StatusCssClass="@WorkflowStageUi.DecisionCssClass(statusLabel)"
                CssClass="agent-rai"
                PanelId="stage-fairness-review"
                IsCollapsible="true"
                CollapsedByDefault="true">
        @if (!string.IsNullOrWhiteSpace(Result.Summary))
        {
            <p class="agent-summary"><strong>What happened:</strong> @Result.Summary</p>
        }
        else
        {
            <p class="agent-summary">
                @(Result.Passed ? "The governance review did not identify blocking fairness concerns." : "The governance review surfaced concerns that require attention.")
            </p>
        }

        @if (!string.IsNullOrWhiteSpace(Result.Decision))
        {
            <div class="recommendation-card @WorkflowStageUi.DecisionCssClass(Result.Decision)">
                <span class="recommendation-label">Governance decision</span>
                <span class="recommendation-value">@Result.Decision</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Result.ApprovalAssessment))
        {
            <p class="agent-metric"><strong>Approval assessment:</strong> @Result.ApprovalAssessment</p>
        }

        @if (!string.IsNullOrWhiteSpace(Result.BiasRisk))
        {
            <p class="agent-metric"><strong>Bias risk:</strong> @Result.BiasRisk</p>
        }

        @if (Result.PolicyRefs?.Count > 0)
        {
            <div class="agent-detail-block">
                <h4>Policy references</h4>
                <EvidenceList Items="Result.PolicyRefs" />
            </div>
        }

        @if (Result.SupportingFacts?.Count > 0)
        {
            <div class="agent-detail-block">
                <h4>Supporting facts</h4>
                <EvidenceList Items="Result.SupportingFacts" />
            </div>
        }
        else if (Result.Observations.Count > 0)
        {
            <div class="agent-detail-block">
                <h4>Supporting facts</h4>
                <EvidenceList Items="Result.Observations" />
            </div>
        }

        @if (Result.Concerns?.Count > 0)
        {
            <div class="agent-detail-block">
                <h4>Concerns</h4>
                <FlagList Items="Result.Concerns" Variant="flag-warning" />
            </div>
        }

        @if (Result.Recommendations?.Count > 0)
        {
            <div class="agent-detail-block">
                <h4>Recommendations</h4>
                <EvidenceList Items="Result.Recommendations" />
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Result.Evidence))
        {
            <div class="agent-detail-block">
                <EvidenceDisclosurePanel Title="Evidence reviewed"
                                         Items="[Result.Evidence]"
                                         EmptyMessage="No evidence narrative recorded." />
            </div>
        }

        @if (Result.FlagItems?.Count > 0)
        {
            <div class="agent-detail-block">
                <h4>Bias indicators</h4>
                <StructuredFlagList Items="Result.FlagItems" />
            </div>
        }

        @if (Result.FairnessFlags.Count > 0 && Result.Concerns?.Count != Result.FairnessFlags.Count)
        {
            <div class="agent-detail-block">
                <h4>Decision flags</h4>
                <FlagList Items="Result.FairnessFlags" Variant="flag-warning" />
            </div>
        }

        <div class="agent-detail-block">
            <h4>Escalation status</h4>
            <p class="agent-summary">@(Result.EscalationRecommended ? "Escalation is recommended before final completion." : "No additional escalation is recommended.")</p>
        </div>

        <div class="agent-detail-block">
            <h4>Next step</h4>
            <p class="agent-summary">@(Result.Passed ? "Proceed to account setup." : "Resolve the governance concerns before continuing.")</p>
        </div>

        @if (Result.RequiresHumanReview)
        {
            <p class="rai-escalation">This governance step keeps the case under visible oversight.</p>
        }
    </AgentPanel>
}

@code {
    [Parameter]
    public ResponsibleAiResultDto? Result { get; set; }
}
