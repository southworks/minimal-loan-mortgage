<span class="status-badge @CssClass" title="@Status">@Label</span>

@code {
    [Parameter, EditorRequired]
    public string Status { get; set; } = string.Empty;

    [Parameter]
    public string? Label { get; set; }

    private string CssClass => Status switch
    {
        "AwaitingHumanApproval" => "badge-review",
        "Approved" or "Completed" or "Succeeded" => "badge-success",
        "Rejected" or "Failed" => "badge-danger",
        "InReview" or "InProgress" => "badge-progress",
        _ => "badge-neutral"
    };
}
