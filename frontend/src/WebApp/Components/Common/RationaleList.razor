@using Cohere.LoanProcessing.Shared.Contracts.Agents

@if (Items is null || Items.Count == 0)
{
    <p class="text-muted">No rationale items recorded.</p>
}
else
{
    <ul class="rationale-list">
        @foreach (var item in Items)
        {
            <li class="rationale-item @SeverityClass(item.Severity)">
                <span class="rationale-code">@item.Code</span>
                <span class="rationale-message">@item.Message</span>
            </li>
        }
    </ul>
}

@code {
    [Parameter]
    public IReadOnlyList<RationaleItem>? Items { get; set; }

    private static string SeverityClass(FlagSeverity severity) => severity switch
    {
        FlagSeverity.Critical => "flag-severity-critical",
        FlagSeverity.High => "flag-severity-high",
        FlagSeverity.Warning => "flag-severity-warning",
        _ => "flag-severity-info"
    };
}
