# Copy to .env.local (same folder) and fill in values.
# Used by .vscode/launch.json when debugging from Cursor/VS Code.

AZURE_FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
AZURE_STORAGE_BLOB_SERVICE_URI=https://yourstorage.blob.core.windows.net/

AzureSearch__Endpoint=https://your-search.search.windows.net
AzureSearch__EvidenceIndexName=loan-case-evidence
AzureSearch__PolicyIndexName=loan-policy-knowledge
AzureSearch__VectorDimensions=1024

AzureStorage__ContainerName=loan-documents

AzureFoundryModels__EmbedDeploymentName=cohere-embed-v4
AzureFoundryModels__RerankDeploymentName=cohere-rerank-v4-pro
AzureFoundryModels__EmbedModelName=embed-v-4-0
AzureFoundryModels__RerankModelName=Cohere-rerank-v4.0-pro
AzureFoundryModels__EmbedEndpoint=https://your-project.services.ai.azure.com/openai/deployments/cohere-embed-v4
AzureFoundryModels__RerankEndpoint=https://your-project.services.ai.azure.com
AzureFoundryModels__EmbeddingDimensions=1024
AzureFoundryModels__EmbeddingBatchSize=16
AzureFoundryModels__MaxConcurrentEmbeddingRequests=1
AzureFoundryModels__MaxConcurrentRerankRequests=2

# Paths relative to backend/src/Api.Host (the debug working directory).
Dataset__RootPath=../../../dataset-seed
Dataset__PolicyFilePath=../../../dataset-seed/08_policy_rag/general_policy.txt

DocumentExtraction__TextOnlyMode=true
DocumentExtraction__Endpoint=

CaseWorkflow__PreIndexCaseDocuments=true
