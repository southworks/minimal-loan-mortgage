{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureFoundry": {
    "ProjectEndpoint": "",
    "DocumentProcessingAgentName": "document-processing-agent",
    "UnderwritingAgentName": "underwriting-agent",
    "ResponsibleAiAgentName": "responsible-ai-agent",
    "LoanSetupAgentName": "loan-setup-agent"
  },
  "AzureStorage": {
    "ConnectionString": "",
    "BlobServiceUri": "",
    "ContainerName": "loan-documents"
  },
  "Dataset": {
    "RootPath": "../../../dataset-seed",
    "PolicyFilePath": "../../../dataset-seed/08_policy_rag/general_policy.txt"
  },
  "AzureSearch": {
    "Endpoint": "",
    "EvidenceIndexName": "loan-case-evidence",
    "PolicyIndexName": "loan-policy-knowledge",
    "VectorDimensions": 1024
  },
  "AzureFoundryModels": {
    "EmbedDeploymentName": "cohere-embed-v4",
    "RerankDeploymentName": "cohere-rerank-v4-pro",
    "EmbedModelName": "embed-v-4-0",
    "RerankModelName": "Cohere-rerank-v4.0-pro",
    "EmbedEndpoint": "",
    "RerankEndpoint": "",
    "ApiKey": "",
    "EmbeddingDimensions": 1024,
    "EmbeddingBatchSize": 16,
    "MaxConcurrentEmbeddingRequests": 1,
    "MaxConcurrentRerankRequests": 2,
    "RetryEnabled": true,
    "MaxRetryAttempts": 4,
    "BaseDelaySeconds": 1,
    "MaxDelaySeconds": 30
  },
  "DocumentExtraction": {
    "TextOnlyMode": true,
    "Endpoint": ""
  },
  "CaseWorkflow": {
    "PreIndexCaseDocuments": true
  },
  "Governance": {
    "EnableFoundryAgentGovernance": true,
    "EnableMcpToolGovernance": true,
    "RequireMcpAgentRoleHeader": true,
    "AgentAuditStoreDirectory": "data/agent-governance-audit"
  }
}
